<+>services:\r\n  # 1. El Directorio (Debe iniciar primero)\r\n  eureka-server:\r\n    build: ./eureka-server\r\n    container_name: eureka-server\r\n    ports:\r\n      - \"8761:8761\"\r\n    environment:\r\n      SERVER_PORT: 8761\r\n    healthcheck:\r\n      test: [ \"CMD-SHELL\", \"curl -f http://localhost:8761/ || exit 1\" ]\r\n      interval: 30s\r\n      timeout: 10s\r\n      retries: 10\r\n      start_period: 60s\r\n    restart: unless-stopped\r\n    networks:\r\n      - bomberos-net\r\n\r\n  # 2. API Gateway\r\n  api-gateway:\r\n    build: ./api-gateway\r\n    container_name: api-gateway-service\r\n    ports:\r\n      - \"9090:9090\"\r\n    environment:\r\n      SERVER_PORT: 9090\r\n      EUREKA_URL: http://eureka-server:8761/eureka/\r\n    depends_on:\r\n      eureka-server:\r\n        condition: service_healthy\r\n    healthcheck:\r\n      test: [\"CMD-SHELL\", \"curl -f http://localhost:9090/actuator/health || exit 1\"]\r\n      interval: 10s\r\n      timeout: 5s\r\n      retries: 10\r\n    restart: unless-stopped\r\n    networks:\r\n      - bomberos-net\r\n\r\n  # 3. Servicio de Usuarios\r\n  usuarios:\r\n    build: ./usuarios\r\n    container_name: usuarios-service\r\n    ports:\r\n      - \"8081:8081\"\r\n    environment:\r\n      SERVER_PORT: 8081\r\n      EUREKA_URL: http://eureka-server:8761/eureka/\r\n    depends_on:\r\n      eureka-server:\r\n        condition: service_healthy\r\n    healthcheck:\r\n      test: [\"CMD-SHELL\", \"curl -f http://localhost:8081/actuator/health || exit 1\"]\r\n      interval: 10s\r\n      timeout: 5s\r\n      retries: 10\r\n    restart: unless-stopped\r\n    networks:\r\n      - bomberos-net\r\n\r\n  # 4. Servicio de Reportes\r\n  reportes:\r\n    build: ./reportes\r\n    container_name: reportes-service\r\n    ports:\r\n      - \"8080:8080\"\r\n    environment:\r\n      SERVER_PORT: 8080\r\n      EUREKA_URL: http://eureka-server:8761/eureka/\r\n    depends_on:\r\n      eureka-server:\r\n        condition: service_healthy\r\n    healthcheck:\r\n      test: [\"CMD-SHELL\", \"curl -f http://localhost:8080/actuator/health || exit 1\"]\r\n      interval: 10s\r\n      timeout: 5s\r\n      retries: 10\r\n    restart: unless-stopped\r\n    networks:\r\n      - bomberos-net\r\n\r\n  # 5. Servicio de Monitoreo\r\n  monitoreo:\r\n    build: ./monitoreo\r\n    container_name: monitoreo-service\r\n    ports:\r\n      - \"8082:8082\"\r\n    environment:\r\n      SERVER_PORT: 8082\r\n      EUREKA_URL: http://eureka-server:8761/eureka/\r\n    depends_on:\r\n      eureka-server:\r\n        condition: service_healthy\r\n    healthcheck:\r\n      test: [\"CMD-SHELL\", \"curl -f http://localhost:8082/actuator/health || exit 1\"]\r\n      interval: 10s\r\n      timeout: 5s\r\n      retries: 10\r\n    restart: unless-stopped\r\n    networks:\r\n      - bomberos-net\r\n\r\n  # 6. Servicio de Alertas\r\n  alertas:\r\n    build: ./alertas\r\n    container_name: alertas-service\r\n    ports:\r\n      - \"8083:8083\"\r\n    environment:\r\n      SERVER_PORT: 8083\r\n      EUREKA_URL: http://eureka-server:8761/eureka/\r\n    depends_on:\r\n      eureka-server:\r\n        condition: service_healthy\r\n    healthcheck:\r\n      test: [\"CMD-SHELL\", \"curl -f http://localhost:8083/actuator/health || exit 1\"]\r\n      interval: 10s\r\n      timeout: 5s\r\n      retries: 10\r\n    restart: unless-stopped\r\n    networks:\r\n      - bomberos-net\r\n\r\n  # 7. Servicio de Historial\r\n  historial:\r\n    build: ./historial\r\n    container_name: historial-service\r\n    ports:\r\n      - \"8084:8084\"\r\n    environment:\r\n      SERVER_PORT: 8084\r\n      EUREKA_URL: http://eureka-server:8761/eureka/\r\n    depends_on:\r\n      eureka-server:\r\n        condition: service_healthy\r\n    healthcheck:\r\n      test: [\"CMD-SHELL\", \"curl -f http://localhost:8084/actuator/health || exit 1\"]\r\n      interval: 10s\r\n      timeout: 5s\r\n      retries: 10\r\n    restart: unless-stopped\r\n    networks:\r\n    